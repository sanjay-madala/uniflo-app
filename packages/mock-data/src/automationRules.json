{
  "rules": [
    {
      "id": "rule_001",
      "name": "Audit fail creates CAPA",
      "description": "When an audit fails, automatically create a CAPA and notify the responsible manager for immediate corrective action.",
      "status": "active",
      "trigger": {
        "event": "audit_failed",
        "label": "Audit failed",
        "icon": "ClipboardX",
        "module": "audits"
      },
      "conditions": [
        {
          "id": "cond_001",
          "field": "score",
          "operator": "less_than",
          "value": 70
        }
      ],
      "actions": [
        {
          "id": "act_001",
          "type": "create_capa",
          "label": "Create CAPA",
          "icon": "AlertTriangle",
          "config": {
            "title": "Fix: {{trigger.finding}}",
            "owner_id": "usr_002",
            "severity": "high"
          }
        },
        {
          "id": "act_002",
          "type": "send_notification",
          "label": "Send Notification",
          "icon": "Bell",
          "config": {
            "channel": "email",
            "recipients": "manager",
            "message": "Audit failed at {{trigger.location}}. CAPA created automatically."
          }
        }
      ],
      "created_by": "usr_001",
      "created_at": "2026-03-01T09:00:00Z",
      "updated_at": "2026-03-10T14:30:00Z",
      "last_triggered_at": "2026-03-13T14:15:00Z",
      "execution_count": 45,
      "success_count": 43,
      "failure_count": 2,
      "template_id": "tmpl_001",
      "location_scope": []
    },
